{
  "scripts": {
    "build": "rsbuild build",
    "check": "biome check --write .",
    "distribute": "electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "package": "electron-builder --dir",
    "start": "electron .",
    "test": "playwright test",
    "types": "tsc",
    "watch": "rsbuild build --watch",
    "web": "rsbuild dev --open"
  },
  "build": {
    "directories": {
      "output": "executable"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.0",
    "@playwright/test": "^1.56.1",
    "@rsbuild/core": "^1.5.17",
    "@rsbuild/plugin-react": "^1.4.1",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "electron": "^38.4.0",
    "electron-builder": "^26.0.12",
    "playwright": "^1.56.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^5.9.3",
    "zero-configuration": "^1.0.9"
  },
  "trustedDependencies": [
    "zero-configuration",
    "electron"
  ],
  "type": "module",
  "main": "main.js"
}
