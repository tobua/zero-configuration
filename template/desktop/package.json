{
  "scripts": {
    "build": "rsbuild build",
    "check": "biome check --write .",
    "distribute": "electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "package": "electron-builder --dir",
    "start": "electron .",
    "test": "playwright test",
    "types": "tsc",
    "watch": "rsbuild build --watch",
    "web": "rsbuild dev --open"
  },
  "build": {
    "directories": {
      "output": "executable"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@playwright/test": "^1.58.2",
    "@rsbuild/core": "^1.7.3",
    "@rsbuild/plugin-react": "^1.4.6",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3",
    "zero-configuration": "^1.0.11"
  },
  "trustedDependencies": [
    "zero-configuration",
    "electron"
  ],
  "type": "module",
  "main": "main.js"
}
